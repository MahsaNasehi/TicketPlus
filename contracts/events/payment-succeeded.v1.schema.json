{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ticketplus.example/schemas/payment-succeeded.v1.json",
  "title": "PaymentSucceeded",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "aggregateId", "occurredAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "PaymentSucceeded" },
    "schemaVersion": { "const": 1 },
    "aggregateId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reservationId", "amountMinor", "currency"],
      "properties": {
        "reservationId": { "type": "string", "format": "uuid" },
        "amountMinor": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    }
  }
}

