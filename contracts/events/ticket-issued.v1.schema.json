{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ticketplus.example/schemas/ticket-issued.v1.json",
  "title": "TicketIssued",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "aggregateId", "occurredAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "TicketIssued" },
    "schemaVersion": { "const": 1 },
    "aggregateId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticketId", "reservationId", "qrHash"],
      "properties": {
        "ticketId": { "type": "string", "format": "uuid" },
        "reservationId": { "type": "string", "format": "uuid" },
        "qrHash": { "type": "string", "minLength": 16 }
      }
    }
  }
}

