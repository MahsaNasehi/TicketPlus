    1: import tempfile
    1: import unittest
    1: from pathlib import Path
       
    1: from ticketplus.checkout import CheckoutService, NotificationService, PaymentResult, TicketingService
    1: from ticketplus.events import EventBus
    1: from ticketplus.reservation import ReservationService
       
       
    2: class CheckoutTests(unittest.TestCase):
    1:     def setUp(self):
    3:         self.temp = tempfile.TemporaryDirectory()
    3:         self.bus = EventBus()
    3:         self.reservations = ReservationService(Path(self.temp.name) / "test.db", self.bus)
    3:         self.ticketing = TicketingService(self.bus)
    3:         self.notifications = NotificationService(self.bus)
       
    1:     def tearDown(self):
    3:         self.temp.cleanup()
       
    1:     def reservation(self):
    3:         return self.reservations.lock_seats("buyer", "event", ["A-1"], "reservation-key")
       
    1:     def test_success_confirms_and_issues_one_ticket(self):
    1:         reservation = self.reservation()
    2:         service = CheckoutService(
    2:             self.reservations, self.bus, lambda key, amount, currency: (PaymentResult.SUCCEEDED, "ref")
               )
    1:         first = service.checkout(reservation["id"], 10000, "IRR", "payment-key")
    1:         second = service.checkout(reservation["id"], 10000, "IRR", "payment-key")
    1:         self.assertEqual(first, second)
    1:         self.assertEqual("CONFIRMED", self.reservations.get(reservation["id"])["status"])
    1:         self.assertEqual(1, len(self.ticketing.tickets))
    1:         self.assertEqual(1, len(self.notifications.deliveries))
       
    1:     def test_definitive_failure_releases_seat(self):
    1:         reservation = self.reservation()
    2:         service = CheckoutService(
    2:             self.reservations, self.bus, lambda key, amount, currency: (PaymentResult.FAILED, None)
               )
    1:         service.checkout(reservation["id"], 10000, "IRR", "payment-key")
    1:         self.assertEqual("CANCELLED", self.reservations.get(reservation["id"])["status"])
       
    1:     def test_unknown_payment_keeps_reservation_for_reconciliation(self):
    1:         reservation = self.reservation()
    2:         service = CheckoutService(
    2:             self.reservations, self.bus, lambda key, amount, currency: (PaymentResult.UNKNOWN, None)
               )
    1:         service.checkout(reservation["id"], 10000, "IRR", "payment-key")
    1:         self.assertEqual("PENDING", self.reservations.get(reservation["id"])["status"])
       
       
    1: if __name__ == "__main__":
           unittest.main()
       
